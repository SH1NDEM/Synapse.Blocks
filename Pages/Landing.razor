@page "/"
@inject LevelStore LevelStore
@inject ProgressStore ProgressStore

<PageTitle>Синапс — Город Ноль</PageTitle>

@if (_loading)
{
    <div class="page-loading"><span></span><p>Подключаюсь к Городу Ноль…</p></div>
}
else
{
    <section class="city-home">
        <div class="city-home-grid" aria-hidden="true"></div>
        <div class="city-hero-copy">
            <div class="season-label"><span>СЕЗОН 01</span> ГОРОД НОЛЬ</div>
            <h1>Запустите город<br /><em>своей логикой.</em></h1>
            <p>Сеть пережила аварию. Восстанавливайте районы, расследуйте следы взлома и создавайте программы для жителей — одна проверка за другой.</p>
            <div class="city-actions">
                <a class="city-primary" href="game">@(_completed.Count > 0 ? "Продолжить кампанию" : "Начать кампанию") <span>→</span></a>
                <a class="city-secondary" href="guide">Как работают блоки</a>
            </div>
            <div class="campaign-summary">
                <div><strong>@_levels.Count</strong><span>операций</span></div>
                <div><strong>@_completed.Count</strong><span>завершено</span></div>
                <div><strong>@ProgressPercent%</strong><span>сеть города</span></div>
            </div>
        </div>

        <div class="logic-window" aria-label="Пример программы из блоков">
            <div class="logic-window-head">
                <span><i></i><i></i><i></i></span>
                <b>ПРОГРАММА / СИГНАЛ A-17</b>
                <small><i></i> ГОТОВА К ЗАПУСКУ</small>
            </div>
            <div class="logic-board">
                <div class="logic-board-grid" aria-hidden="true"></div>
                <svg class="logic-wires" viewBox="0 0 760 350" aria-hidden="true">
                    <path d="M 205 175 C 252 175, 255 105, 304 105" />
                    <path d="M 472 105 C 522 105, 522 175, 570 175" />
                    <path class="logic-flow" d="M 205 175 C 252 175, 255 105, 304 105 M 472 105 C 522 105, 522 175, 570 175" />
                </svg>

                <article class="logic-node logic-input">
                    <span>ДАННЫЕ</span><h3>Вход</h3><p>Получить значение теста</p>
                    <div><small>ПОЛУЧАЕТ</small><b>15</b></div><i class="logic-port out"></i>
                </article>
                <article class="logic-node logic-operation">
                    <span>КОМАНДА</span><h3>Умножить</h3><p>Изменить текущее значение</p>
                    <div><small>ЗНАЧЕНИЕ</small><b>× 2</b></div><i class="logic-port input"></i><i class="logic-port out"></i>
                </article>
                <article class="logic-node logic-output">
                    <span>РЕЗУЛЬТАТ</span><h3>Выход</h3><p>Вернуть ответ программы</p>
                    <div><small>РЕЗУЛЬТАТ</small><b>30</b></div><i class="logic-port input"></i>
                </article>

                <div class="logic-test-card"><span>ТЕСТ 01</span><b>15 → 30</b><small>ПРОЙДЕН</small></div>
                <div class="logic-hint"><i></i><span>Данные проходят по связям между блоками</span></div>
            </div>
            <div class="logic-window-foot">
                <span><i></i> 3 блока</span><span>2 связи</span><b>Результат совпал ✓</b>
            </div>
        </div>
    </section>

    <section class="campaign-section">
        <div class="campaign-heading"><div><small>// МАРШРУТ СИНАПСА</small><h2>Операции кампании</h2></div><p>Каждое решение меняет состояние города и открывает следующий фрагмент истории.</p></div>
        <div class="campaign-levels">
            @foreach (var level in _levels)
            {
                var complete = _completed.Contains(level.Id);
                <a class="campaign-level @(complete ? "complete" : "")" href="game?level=@level.Id">
                    <span class="campaign-index">@level.Order.ToString("00")</span>
                    <div><small>@level.Location</small><h3>@level.Title</h3><p>@level.Description</p></div>
                    <b>@(complete ? "✓" : "→")</b>
                </a>
            }
        </div>
    </section>
}

@code {
    private List<LevelDefinition> _levels = [];
    private HashSet<Guid> _completed = [];
    private bool _loading = true;
    private int ProgressPercent => _levels.Count == 0 ? 0 : (int)Math.Round(_completed.Count * 100d / _levels.Count);

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _levels = await LevelStore.LoadAsync();
            _completed = await ProgressStore.LoadAsync();
        }
        finally
        {
            // Даже повреждённое локальное сохранение не оставляет главную на вечной загрузке.
            _loading = false;
        }
    }
}
