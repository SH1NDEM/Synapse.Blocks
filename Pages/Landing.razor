@page "/"
@inject LevelStore LevelStore
@inject ProgressStore ProgressStore

<PageTitle>Синапс — Город Ноль</PageTitle>

@if (_loading)
{
    <div class="page-loading"><span></span><p>Подключаюсь к Городу Ноль…</p></div>
}
else
{
    <section class="city-home">
        <div class="city-home-grid" aria-hidden="true"></div>
        <div class="city-hero-copy">
            <div class="season-label"><span>СЕЗОН 01</span> ГОРОД НОЛЬ</div>
            <h1>Запустите город<br /><em>своей логикой.</em></h1>
            <p>Сеть пережила аварию. Восстанавливайте районы, расследуйте следы взлома и создавайте программы для жителей — одна проверка за другой.</p>
            <div class="city-actions">
                <a class="city-primary" href="game">@(_completed.Count > 0 ? "Продолжить кампанию" : "Начать кампанию") <span>→</span></a>
                <a class="city-secondary" href="editor">Создать свой уровень</a>
            </div>
            <div class="campaign-summary">
                <div><strong>@_levels.Count</strong><span>операций</span></div>
                <div><strong>@_completed.Count</strong><span>завершено</span></div>
                <div><strong>@ProgressPercent%</strong><span>сеть города</span></div>
            </div>
        </div>

        <div class="city-window" aria-label="Изометрическая карта Города Ноль">
            <div class="city-window-head"><span><i></i><i></i><i></i></span><b>СЕКТОР 00 / LIVE MAP</b><small><i></i> СЕТЬ АКТИВНА</small></div>
            <div class="iso-city">
                <div class="city-map">
                    <div class="city-road road-horizontal road-h-1"></div>
                    <div class="city-road road-horizontal road-h-2"></div>
                    <div class="city-road road-horizontal road-h-3"></div>
                    <div class="city-road road-vertical road-v-1"></div>
                    <div class="city-road road-vertical road-v-2"></div>
                    <div class="city-road road-vertical road-v-3"></div>

                    <span class="city-crossing crossing-1"></span><span class="city-crossing crossing-2"></span>
                    <span class="city-crossing crossing-3"></span><span class="city-crossing crossing-4"></span>
                    <span class="city-crossing crossing-5"></span><span class="city-crossing crossing-6"></span>
                    <span class="city-crossing crossing-7"></span><span class="city-crossing crossing-8"></span>
                    <span class="city-crossing crossing-9"></span>

                    <div class="city-park park-a"><i></i><i></i><i></i><i></i><b>СКВЕР</b></div>
                    <div class="city-park park-b"><i></i><i></i><i></i><b>САД</b></div>

                    @foreach (var building in CityBuildings)
                    {
                        <div class="iso-building city-building" style="@building.Style">
                            @if (building.Beacon)
                            {
                                <span class="roof-light"></span>
                            }
                            @if (building.Antenna)
                            {
                                <span class="antenna"></span>
                            }
                            <i></i><i></i><i></i><i></i><i></i><b>@building.Label</b>
                        </div>
                    }

                    <span class="traffic-light traffic-1"><i></i><i></i><i></i></span>
                    <span class="traffic-light traffic-2"><i></i><i></i><i></i></span>
                    <span class="traffic-light traffic-3"><i></i><i></i><i></i></span>
                    <span class="traffic-light traffic-4"><i></i><i></i><i></i></span>
                    <span class="traffic-light traffic-5"><i></i><i></i><i></i></span>
                    <span class="traffic-light traffic-6"><i></i><i></i><i></i></span>

                    <span class="city-car car-1"></span><span class="city-car car-2"></span><span class="city-car car-3"></span>
                    <span class="city-car car-4"></span><span class="city-car car-5"></span><span class="city-car car-6"></span>
                    <span class="city-car car-7"></span><span class="city-car car-8"></span>

                    @foreach (var person in CityPeople)
                    {
                        <span class="city-person" style="@person"></span>
                    }

                    <span class="street-light light-1"></span><span class="street-light light-2"></span><span class="street-light light-3"></span>
                    <span class="street-light light-4"></span><span class="street-light light-5"></span><span class="street-light light-6"></span>
                    <span class="street-light light-7"></span><span class="street-light light-8"></span><span class="street-light light-9"></span>
                    <span class="street-light light-10"></span><span class="street-light light-11"></span><span class="street-light light-12"></span>
                    <span class="data-pulse pulse-1"></span><span class="data-pulse pulse-2"></span><span class="data-pulse pulse-3"></span>
                </div>
            </div>
            <div class="city-readout">
                <div><small>ЭНЕРГИЯ</small><strong>@Math.Max(12, ProgressPercent)%</strong></div>
                <p><i></i> Ретрансляторы ожидают новые программы</p>
                <span>@DateTime.Now.ToString("HH:mm")</span>
            </div>
        </div>
    </section>

    <section class="campaign-section">
        <div class="campaign-heading"><div><small>// МАРШРУТ СИНАПСА</small><h2>Операции кампании</h2></div><p>Каждое решение меняет состояние города и открывает следующий фрагмент истории.</p></div>
        <div class="campaign-levels">
            @foreach (var level in _levels)
            {
                var complete = _completed.Contains(level.Id);
                <a class="campaign-level @(complete ? "complete" : "")" href="game?level=@level.Id">
                    <span class="campaign-index">@level.Order.ToString("00")</span>
                    <div><small>@level.Location</small><h3>@level.Title</h3><p>@level.Description</p></div>
                    <b>@(complete ? "✓" : "→")</b>
                </a>
            }
        </div>
    </section>
}

@code {
