    private static readonly string[] CityPeople =
    [
        "--x:112px;--y:157px;--delay:.1s", "--x:133px;--y:164px;--delay:.8s", "--x:354px;--y:155px;--delay:.4s",
        "--x:573px;--y:158px;--delay:1.1s", "--x:748px;--y:159px;--delay:.2s", "--x:210px;--y:325px;--delay:1.3s",
        "--x:341px;--y:325px;--delay:.7s", "--x:548px;--y:320px;--delay:1.6s", "--x:774px;--y:326px;--delay:.5s",
        "--x:280px;--y:94px;--delay:1s", "--x:492px;--y:238px;--delay:.3s", "--x:699px;--y:420px;--delay:1.4s"
    ];

    protected override async Task OnInitializedAsync()
    {
        _levels = await LevelStore.LoadAsync();
        _completed = await ProgressStore.LoadAsync();
        _loading = false;
    }

    private sealed record CityBuilding(string Label, string Style, bool Beacon, bool Antenna);
}
