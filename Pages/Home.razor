    private string NodeStyle(BlockNode node)
        => $"left:{CanvasNumber(node.X + CanvasOffsetX)}px;top:{CanvasNumber(node.Y + CanvasOffsetY)}px;width:{NodeWidth}px;height:{CanvasNumber(NodeHeight(node.Kind))}px;";

    private string ConnectionPath(BlockNode from, BlockNode to, BlockConnection edge)
    {
        // У возврата цикла вход расположен снизу, у остальных блоков — слева.
        var x1 = from.X + CanvasOffsetX + NodeWidth;
        var y1 = from.Y + CanvasOffsetY + PortOffset(from.Kind, edge.Port);
        var returnTarget = edge.TargetPort == TargetPort.Return;
        var x2 = returnTarget ? to.X + CanvasOffsetX + NodeWidth / 2 : to.X + CanvasOffsetX;
        var y2 = returnTarget ? to.Y + CanvasOffsetY + NodeHeight(to.Kind) : to.Y + CanvasOffsetY + NodeHeight(to.Kind) / 2;
        if (returnTarget)
        {
            var vertical = Math.Clamp(Math.Abs(y2 - y1) * .35, 26, 82);
            var horizontal = Math.Clamp(Math.Abs(x2 - x1) * .26, 18, 72);
            return FormattableString.Invariant($"M {x1} {y1} C {x1 + horizontal} {y1}, {x2} {y2 + vertical}, {x2} {y2}");
        }
        return BezierPath(x1, y1, x2, y2);
    }

    private string PreviewPath(BlockNode from)
    {
        var x1 = from.X + CanvasOffsetX + NodeWidth;
        var y1 = from.Y + CanvasOffsetY + PortOffset(from.Kind, _connectingPort);
        return BezierPath(x1, y1, _pointerX, _pointerY);
    }

    private static string BezierPath(double x1, double y1, double x2, double y2)
    {
        // Ограниченные управляющие точки не дают короткой связи сделать большой крюк.
        var dx = x2 - x1;
        var dy = y2 - y1;
        if (dx >= 0)
        {
            var pull = Math.Clamp(dx * .42, 8, 120);
            return FormattableString.Invariant($"M {x1} {y1} C {x1 + pull} {y1}, {x2 - pull} {y2}, {x2} {y2}");
        }

        var outward = Math.Clamp(24 + Math.Abs(dy) * .12, 24, 64);
        return FormattableString.Invariant($"M {x1} {y1} C {x1 + outward} {y1}, {x2 - outward} {y2}, {x2} {y2}");
    }

    private string ResultClass(Guid nodeId)
    {
        if (_executionErrorNode == nodeId) return "node-error";
        if (_activeExecutionNode == nodeId) return "node-running";
        if (_executedNodes.Contains(nodeId)) return "node-pass";
        return "";
    }

    private string WireExecutionClass(BlockConnection edge)
        => IsWireActive(edge) ? "wire-active" : "";

    private bool IsWireActive(BlockConnection edge)
        => _previousExecutionNode == edge.FromNodeId && _activeExecutionNode == edge.ToNodeId;

    private bool IsHiddenResult(TestRunResult result)
        => ActiveLevel?.Tests.FirstOrDefault(test => test.Id == result.TestId)?.Hidden == true;

    private string ResultTitle(TestRunResult result)
    {
        if (!IsHiddenResult(result)) return result.Name;
        var index = ActiveLevel?.Tests.FindIndex(test => test.Id == result.TestId) ?? -1;
        return $"Скрытая проверка {(index >= 0 ? index + 1 : 0)}";
    }

    private string ResultDetail(TestRunResult result)
    {
        if (IsHiddenResult(result))
        {
            if (result.Passed) return "скрытая проверка пройдена";
            var values = $"вход: {RuntimeDisplay(result.Input)} · ожидалось: {RuntimeDisplay(result.Expected)} · получено: {RuntimeDisplay(result.Actual)}";
            return string.IsNullOrWhiteSpace(result.Error) ? values : $"{result.Error} · {values}";
        }
        if (result.Passed) return $"получено: {result.Actual}";
        return !string.IsNullOrWhiteSpace(result.Error)
            ? result.Error
            : $"ожидалось {result.Expected}, получено {result.Actual}";
    }

    private static string RuntimeDisplay(string value)
        => string.IsNullOrEmpty(value) ? "∅ пусто" : value;

    private static string HelpSummary(BlockKind kind) => kind switch
    {
        BlockKind.Input => "Начало программы. На каждом тесте этот блок автоматически получает новые данные уровня.",
        BlockKind.Operation => "Изменяет текущее значение. Действие выбирается из списка, а параметр вводится в отдельном поле.",
        BlockKind.Condition => "Сравнивает входное значение и направляет выполнение по синей или красной ветке.",
        BlockKind.Loop => "Повторяет подключённую цепочку заданное число раз и после каждого шага принимает возврат снизу.",
        BlockKind.Output => "Завершает программу и отправляет фактический результат в систему тестов.",
        _ => ""
    };

    private static string HelpInput(BlockKind kind) => kind switch
    {
        BlockKind.Input => "Данные выдаёт уровень — внешнего входа нет.",
        BlockKind.Loop => "Слева — данные, снизу — возврат после повтора.",
        _ => "Значение от предыдущего блока."
    };

    private static string HelpOutput(BlockKind kind) => kind switch
    {
        BlockKind.Output => "Выходов нет — программа завершена.",
        BlockKind.Condition => "Синий — условие верно, красный — неверно.",
        BlockKind.Loop => "Сверху — выход, ниже — следующий повтор.",
        _ => "Одно значение для следующего блока."
    };

    private static string[] HelpSteps(BlockKind kind) => kind switch
    {
        BlockKind.Input => ["Поставьте блок в начало.", "Он получит данные очередного теста.", "Потяните выход к следующему блоку."],
        BlockKind.Operation => ["Подключите вход.", "Выберите действие в меню.", "Если появилось поле — задайте значение.", "Передайте результат дальше."],
        BlockKind.Condition => ["Подайте значение на вход.", "Напишите только проверку, например > 20.", "Подключите синюю и красную ветки."],
        BlockKind.Loop => ["Подайте данные слева.", "Выберите input или своё число.", "Выход «повтор» соедините с действием.", "Верните действие в нижний порт.", "Верхний выход ведите дальше."],
        BlockKind.Output => ["Поставьте блок в конце.", "Подключите итоговое значение.", "Запустите все тесты уровня."],
        _ => []
    };
}
