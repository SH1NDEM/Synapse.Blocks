    "Description": "\u0421\u0442\u0430\u0440\u044B\u0439 \u0440\u0435\u0442\u0440\u0430\u043D\u0441\u043B\u044F\u0442\u043E\u0440 \u043F\u0435\u0440\u0435\u0434\u0430\u0451\u0442 \u0441\u0438\u0433\u043D\u0430\u043B \u0432 \u0434\u0432\u0430 \u0440\u0430\u0437\u0430 \u0441\u043B\u0430\u0431\u0435\u0435 \u043D\u0443\u0436\u043D\u043E\u0433\u043E.",
    "StoryIntro": "\u041F\u043E\u0441\u043B\u0435 \u0434\u043E\u043B\u0433\u043E\u0439 \u0430\u0432\u0430\u0440\u0438\u0438 \u0413\u043E\u0440\u043E\u0434 \u041D\u043E\u043B\u044C \u043E\u0442\u0432\u0435\u0447\u0430\u0435\u0442 \u043B\u0438\u0448\u044C \u043A\u043E\u0440\u043E\u0442\u043A\u0438\u043C\u0438 \u0438\u043C\u043F\u0443\u043B\u044C\u0441\u0430\u043C\u0438. \u0410\u0441\u0442\u0440\u0430 \u043D\u0430\u0445\u043E\u0434\u0438\u0442 \u0436\u0438\u0432\u043E\u0439 \u0440\u0435\u0442\u0440\u0430\u043D\u0441\u043B\u044F\u0442\u043E\u0440, \u043D\u043E \u0435\u0433\u043E \u043C\u043E\u0449\u043D\u043E\u0441\u0442\u0438 \u043D\u0435 \u0445\u0432\u0430\u0442\u0430\u0435\u0442, \u0447\u0442\u043E\u0431\u044B \u0440\u0430\u0437\u0431\u0443\u0434\u0438\u0442\u044C \u0440\u0430\u0439\u043E\u043D.",
    "StorySuccess": "\u0421\u0438\u0433\u043D\u0430\u043B \u043F\u0440\u043E\u0445\u043E\u0434\u0438\u0442 \u0447\u0435\u0440\u0435\u0437 \u0431\u0430\u0448\u043D\u044E \u0438 \u0437\u0430\u0436\u0438\u0433\u0430\u0435\u0442 \u043F\u0435\u0440\u0432\u0443\u044E \u043B\u0438\u043D\u0438\u044E \u043E\u043A\u043E\u043D. \u041D\u0430 \u043A\u0430\u0440\u0442\u0435 \u043F\u043E\u044F\u0432\u043B\u044F\u0435\u0442\u0441\u044F \u043C\u0430\u0440\u0448\u0440\u0443\u0442 \u043A \u043B\u0430\u0431\u043E\u0440\u0430\u0442\u043E\u0440\u043D\u043E\u043C\u0443 \u0448\u043B\u044E\u0437\u0443.",
    "Objective": "\u0423\u043C\u043D\u043E\u0436\u044C\u0442\u0435 \u0432\u0445\u043E\u0434\u043D\u043E\u0435 \u0447\u0438\u0441\u043B\u043E \u043D\u0430 2 \u0438 \u0432\u0435\u0440\u043D\u0438\u0442\u0435 \u0440\u0435\u0437\u0443\u043B\u044C\u0442\u0430\u0442.",
    "InputDescription": "\u0426\u0435\u043B\u043E\u0435 \u0447\u0438\u0441\u043B\u043E \u2014 \u0441\u0438\u043B\u0430 \u0432\u0445\u043E\u0434\u043D\u043E\u0433\u043E \u0441\u0438\u0433\u043D\u0430\u043B\u0430.",
    "OutputDescription": "\u0423\u0434\u0432\u043E\u0435\u043D\u043D\u0430\u044F \u0441\u0438\u043B\u0430 \u0441\u0438\u0433\u043D\u0430\u043B\u0430.",
    "Hint": "\u0421\u043E\u0435\u0434\u0438\u043D\u0438\u0442\u0435 \u0412\u0445\u043E\u0434 \u2192 \u041E\u043F\u0435\u0440\u0430\u0446\u0438\u044F \u2192 \u0412\u044B\u0445\u043E\u0434. \u0412 \u043E\u043F\u0435\u0440\u0430\u0446\u0438\u0438 \u0432\u044B\u0431\u0435\u0440\u0438\u0442\u0435 \u00AB\u0423\u043C\u043D\u043E\u0436\u0438\u0442\u044C\u00BB \u0438 \u0443\u043A\u0430\u0436\u0438\u0442\u0435 2.",
